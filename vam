#!/usr/bin/env bash
set -euo pipefail

###############################################################################
# vivado_at_mac (vam) — Run Vivado on macOS with a single command
###############################################################################

VAM_VERSION="1.0.0"
VAM_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VAM_HOME="${VAM_HOME:-$HOME/.vivado_at_mac}"
VAM_IMAGE="vivado_at_mac:latest"
VAM_CONTAINER_BUILD="vam_build"
VAM_CONTAINER_GUI="vam_gui"
NOVNC_PORT=6080
XVC_PORT=3721

#=== Colors ===#
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m'

#=== Logging ===#
error()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
info()    { echo -e "${CYAN}[INFO]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
step()    { echo -e "${CYAN}==> $*${NC}"; }

#=== YAML Parsing (pure bash, zero dependencies) ===#
yaml_value() {
    local file="$1" key="$2"
    grep "^${key}:" "$file" 2>/dev/null | head -1 | sed "s/^${key}:[[:space:]]*//"
}

yaml_list() {
    local file="$1" key="$2"
    awk -v key="$key" '
        $0 ~ "^" key ":" {found=1; next}
        found && /^[^[:space:]]/ {exit}
        found && /^[[:space:]]*-/ {sub(/^[[:space:]]*-[[:space:]]*/, ""); print}
    ' "$file"
}

#=== Prerequisite Checks ===#
check_docker() {
    if ! command -v docker &>/dev/null; then
        error "Docker/OrbStack not found."
        info "Install OrbStack: brew install --cask orbstack"
        exit 1
    fi
    if ! docker info &>/dev/null; then
        error "Docker daemon not running. Start OrbStack first."
        exit 1
    fi
}

check_image() {
    if ! docker image inspect "$VAM_IMAGE" &>/dev/null; then
        step "Building Docker image (first time, takes a few minutes)..."
        docker build --platform linux/amd64 -t "$VAM_IMAGE" -f "$VAM_DIR/Dockerfile" "$VAM_DIR"
        success "Docker image built."
    fi
}

check_vivado() {
    if [ ! -d "$VAM_HOME/Xilinx" ] || [ -z "$(ls -A "$VAM_HOME/Xilinx" 2>/dev/null)" ]; then
        error "Vivado not installed."
        info "Run: vam install /path/to/vivado_installer.bin"
        exit 1
    fi
}

get_openfpgaloader() {
    if command -v openFPGALoader &>/dev/null; then
        echo "openFPGALoader"
    elif [ -x "$VAM_DIR/openFPGALoader" ]; then
        echo "$VAM_DIR/openFPGALoader"
    else
        error "openFPGALoader not found."
        info "Install: brew install openfpgaloader"
        info "And deps: brew install libusb libftdi hidapi"
        exit 1
    fi
}

find_fpga_yml() {
    local dir="${1:-.}"
    if [ -f "$dir/fpga.yml" ]; then
        echo "$dir/fpga.yml"
    elif [ -f "$dir/fpga.yaml" ]; then
        echo "$dir/fpga.yaml"
    else
        error "fpga.yml not found in $dir"
        cat << 'EXAMPLE'

Create fpga.yml in your project root:

  project: my_project
  part: xc7a35ticsg324-1L
  top: top_module
  sources:
    - src/*.v
  constraints:
    - constraints/board.xdc
  board: basys3

EXAMPLE
        exit 1
    fi
}

#=== TCL Build Script Generation ===#
generate_build_tcl() {
    local fpga_yml="$1"
    local project_dir="$2"
    local build_dir="$project_dir/build"

    local part top
    part=$(yaml_value "$fpga_yml" "part")
    top=$(yaml_value "$fpga_yml" "top")

    if [ -z "$part" ] || [ -z "$top" ]; then
        error "fpga.yml must have 'part' and 'top' fields."
        exit 1
    fi

    mkdir -p "$build_dir"
    local tcl_file="$build_dir/build.tcl"

    # Header with substituted variables
    cat > "$tcl_file" << EOF
# Auto-generated by vam — do not edit manually
set part "${part}"
set top "${top}"
set outDir "/workspace/build"

file mkdir \$outDir

# Read sources
EOF

    # Source files
    while IFS= read -r pattern; do
        [ -z "$pattern" ] && continue
        case "$pattern" in
            *.sv)       echo "foreach f [glob /workspace/$pattern] { read_verilog -sv \$f }" >> "$tcl_file" ;;
            *.v)        echo "foreach f [glob /workspace/$pattern] { read_verilog \$f }" >> "$tcl_file" ;;
            *.vhd|*.vhdl) echo "foreach f [glob /workspace/$pattern] { read_vhdl \$f }" >> "$tcl_file" ;;
            *)          echo "foreach f [glob /workspace/$pattern] { read_verilog \$f }" >> "$tcl_file" ;;
        esac
    done < <(yaml_list "$fpga_yml" "sources")

    echo "" >> "$tcl_file"
    echo "# Read constraints" >> "$tcl_file"

    # Constraint files
    while IFS= read -r pattern; do
        [ -z "$pattern" ] && continue
        echo "foreach f [glob /workspace/$pattern] { read_xdc \$f }" >> "$tcl_file"
    done < <(yaml_list "$fpga_yml" "constraints")

    # Synthesis + Implementation + Bitstream (TCL variables, no shell expansion)
    cat >> "$tcl_file" << 'TCLEOF'

# Synthesis
puts "==> Starting synthesis..."
synth_design -top $top -part $part
write_checkpoint -force $outDir/post_synth.dcp
report_utilization -file $outDir/utilization.rpt
puts "==> Synthesis complete."

# Implementation
puts "==> Starting implementation..."
opt_design
place_design
phys_opt_design
route_design
write_checkpoint -force $outDir/post_route.dcp
puts "==> Implementation complete."

# Reports
report_timing_summary -file $outDir/timing.rpt
report_power -file $outDir/power.rpt

# Generate bitstream
puts "==> Generating bitstream..."
write_bitstream -force $outDir/${top}.bit
puts "==> Done! Bitstream: $outDir/${top}.bit"
TCLEOF

    echo "$tcl_file"
}

###############################################################################
# Commands
###############################################################################

cmd_install() {
    local bin_path="${1:-}"

    if [ -z "$bin_path" ]; then
        error "Usage: vam install <path_to_vivado_installer.bin>"
        exit 1
    fi

    if [ ! -f "$bin_path" ]; then
        error "File not found: $bin_path"
        exit 1
    fi

    # Resolve to absolute path
    bin_path="$(cd "$(dirname "$bin_path")" && pwd)/$(basename "$bin_path")"

    step "Checking prerequisites..."
    check_docker

    step "Building Docker image..."
    check_image

    # Create persistent directories
    mkdir -p "$VAM_HOME/Xilinx"
    mkdir -p "$VAM_HOME/.Xilinx"

    step "Installing Vivado 2025.2..."
    info "Installer: $bin_path"
    info "Destination: $VAM_HOME/Xilinx/"
    info "This takes 30-60 minutes. Go grab a coffee."
    echo ""

    docker run --init --rm -it \
        --name vam_install \
        --platform linux/amd64 \
        -v "$bin_path":/tmp/vivado_installer.bin:ro \
        -v "$VAM_HOME/Xilinx":/opt/Xilinx \
        -v "$VAM_HOME/.Xilinx":/home/user/.Xilinx \
        -v "$VAM_DIR/scripts":/opt/vam/scripts:ro \
        -v "$VAM_DIR/config":/opt/vam/config:ro \
        "$VAM_IMAGE" \
        bash /opt/vam/scripts/install-vivado.sh

    # Verify
    local v_dir
    v_dir=$(ls -d "$VAM_HOME/Xilinx"/*/Vivado "$VAM_HOME/Xilinx"/Vivado/* 2>/dev/null | head -n 1 || echo "")
    if [ -n "$v_dir" ] && [ -d "$v_dir" ]; then
        echo ""
        success "Vivado 2025.2 installed successfully!"
        info "Location: $VAM_HOME/Xilinx/"
        info "Try: vam build ./path/to/project/"
    else
        error "Installation may have failed. Check output above."
        exit 1
    fi
}

cmd_build() {
    local project_dir="${1:-.}"
    project_dir="$(cd "$project_dir" && pwd)"

    check_docker
    check_image
    check_vivado

    local fpga_yml
    fpga_yml=$(find_fpga_yml "$project_dir")

    local project_name part top
    project_name=$(yaml_value "$fpga_yml" "project")
    part=$(yaml_value "$fpga_yml" "part")
    top=$(yaml_value "$fpga_yml" "top")

    info "Project: ${project_name:-unnamed} | Part: $part | Top: $top"

    step "Generating build script..."
    generate_build_tcl "$fpga_yml" "$project_dir" >/dev/null

    step "Starting Vivado build (batch mode)..."
    echo ""

    docker run --init --rm \
        --name "$VAM_CONTAINER_BUILD" \
        --platform linux/amd64 \
        -v "$project_dir":/workspace \
        -v "$VAM_HOME/Xilinx":/opt/Xilinx:ro \
        -v "$VAM_HOME/.Xilinx":/home/user/.Xilinx \
        "$VAM_IMAGE" \
        bash -c '
            V_DIR=$(ls -d /opt/Xilinx/*/Vivado /opt/Xilinx/Vivado/* 2>/dev/null | head -n 1)
            if [ -z "$V_DIR" ]; then
                echo "ERROR: Vivado not found in /opt/Xilinx"
                exit 1
            fi
            source "$V_DIR/settings64.sh"
            vivado -mode batch -source /workspace/build/build.tcl -nolog -nojournal
        '

    local exit_code=$?
    echo ""

    if [ $exit_code -eq 0 ] && [ -f "$project_dir/build/${top}.bit" ]; then
        success "Build complete!"
        info "Bitstream:    $project_dir/build/${top}.bit"
        info "Utilization:  $project_dir/build/utilization.rpt"
        info "Timing:       $project_dir/build/timing.rpt"
    else
        error "Build failed (exit code: $exit_code)."
        info "Check output above for details."
        exit 1
    fi
}

cmd_program() {
    local bit_file="" board=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --board|-b) board="$2"; shift 2 ;;
            -*)         error "Unknown option: $1"; exit 1 ;;
            *)          bit_file="$1"; shift ;;
        esac
    done

    # Auto-detect from fpga.yml if available
    if [ -f "fpga.yml" ] || [ -f "fpga.yaml" ]; then
        local yml
        yml=$(find_fpga_yml "." 2>/dev/null || echo "")
        if [ -n "$yml" ]; then
            local top
            top=$(yaml_value "$yml" "top")
            [ -z "$bit_file" ] && bit_file="build/${top}.bit"
            [ -z "$board" ] && board=$(yaml_value "$yml" "board")
        fi
    fi

    if [ -z "$bit_file" ]; then
        error "Usage: vam program [bitstream.bit] [--board <name>]"
        info "Or run from a directory with fpga.yml."
        exit 1
    fi

    if [ ! -f "$bit_file" ]; then
        error "Bitstream not found: $bit_file"
        info "Run 'vam build' first."
        exit 1
    fi

    if [ -z "$board" ]; then
        error "Board not specified. Use --board <name> or set 'board:' in fpga.yml."
        exit 1
    fi

    local ofl
    ofl=$(get_openfpgaloader)

    step "Programming $board with $(basename "$bit_file")..."
    "$ofl" -b "$board" "$bit_file"

    success "FPGA programmed successfully!"
}

cmd_gui() {
    local project_dir="${1:-.}"
    project_dir="$(cd "$project_dir" && pwd)"

    check_docker
    check_image
    check_vivado

    # Stop existing GUI container
    if docker ps -q -f name="$VAM_CONTAINER_GUI" 2>/dev/null | grep -q .; then
        warn "Stopping existing GUI session..."
        docker kill "$VAM_CONTAINER_GUI" &>/dev/null || true
        sleep 2
    fi

    # Start XVC bridge if board is connected
    local xvc_pid=""
    local board=""
    if [ -f "$project_dir/fpga.yml" ]; then
        board=$(yaml_value "$project_dir/fpga.yml" "board")
    fi

    if [ -n "$board" ]; then
        local ofl
        if ofl=$(get_openfpgaloader 2>/dev/null); then
            if "$ofl" --detect &>/dev/null; then
                step "Starting XVC bridge for $board..."
                "$ofl" -b "$board" --xvc &
                xvc_pid=$!
                info "XVC server on port $XVC_PORT (PID: $xvc_pid)"
            else
                info "No FPGA board detected. Skipping XVC bridge."
            fi
        fi
    fi

    # Cleanup on exit
    cleanup_gui() {
        echo ""
        info "Stopping GUI session..."
        docker kill "$VAM_CONTAINER_GUI" &>/dev/null || true
        [ -n "$xvc_pid" ] && kill "$xvc_pid" &>/dev/null || true
        success "GUI session ended."
        exit 0
    }
    trap cleanup_gui INT TERM

    step "Starting Vivado GUI (noVNC on port $NOVNC_PORT)..."

    docker run --init --rm \
        --name "$VAM_CONTAINER_GUI" \
        --platform linux/amd64 \
        -p "$NOVNC_PORT:6080" \
        -v "$project_dir":/workspace \
        -v "$VAM_HOME/Xilinx":/opt/Xilinx:ro \
        -v "$VAM_HOME/.Xilinx":/home/user/.Xilinx \
        -v "$VAM_DIR/scripts":/opt/vam/scripts:ro \
        "$VAM_IMAGE" \
        bash /opt/vam/scripts/start-gui.sh &

    local container_pid=$!

    # Wait for noVNC to be ready, then open browser
    sleep 5
    open "http://localhost:$NOVNC_PORT/vnc.html?autoconnect=true" 2>/dev/null || true

    echo ""
    success "Vivado GUI: http://localhost:$NOVNC_PORT"
    info "Press Ctrl+C to stop."
    echo ""

    wait $container_pid 2>/dev/null || true
    cleanup_gui
}

cmd_status() {
    echo "=== vivado_at_mac v${VAM_VERSION} ==="
    echo ""

    # Docker/OrbStack
    if command -v docker &>/dev/null && docker info &>/dev/null; then
        success "Docker/OrbStack: running"
    else
        error "Docker/OrbStack: not found or not running"
    fi

    # Docker image
    if docker image inspect "$VAM_IMAGE" &>/dev/null; then
        success "Docker image: built"
    else
        warn "Docker image: not built (will build on first use)"
    fi

    # Vivado installation
    if [ -d "$VAM_HOME/Xilinx" ] && [ -n "$(ls -A "$VAM_HOME/Xilinx" 2>/dev/null)" ]; then
        local v_dir
        v_dir=$(ls -d "$VAM_HOME/Xilinx"/*/Vivado "$VAM_HOME/Xilinx"/Vivado/* 2>/dev/null | head -n 1 || echo "")
        if [ -n "$v_dir" ]; then
            success "Vivado: installed ($VAM_HOME/Xilinx/)"
        else
            warn "Vivado: directory exists but may be incomplete"
        fi
    else
        warn "Vivado: not installed"
    fi

    # openFPGALoader
    if command -v openFPGALoader &>/dev/null; then
        success "openFPGALoader: installed"
    elif [ -x "$VAM_DIR/openFPGALoader" ]; then
        success "openFPGALoader: bundled binary"
    else
        warn "openFPGALoader: not found (brew install openfpgaloader)"
    fi

    # Running containers
    echo ""
    if docker ps -q -f name=vam_ 2>/dev/null | grep -q .; then
        info "Running containers:"
        docker ps -f name=vam_ --format "  {{.Names}} ({{.Status}})"
    else
        info "No vam containers running."
    fi
}

cmd_clean() {
    local project_dir="${1:-.}"

    if [ -d "$project_dir/build" ]; then
        rm -rf "$project_dir/build"
        success "Cleaned: $project_dir/build/"
    else
        info "Nothing to clean."
    fi
}

cmd_uninstall() {
    if [ ! -d "$VAM_HOME" ]; then
        info "Nothing to uninstall."
        return
    fi

    warn "This will remove Vivado installation (~40GB)."
    warn "Location: $VAM_HOME/"
    echo -n "Continue? [y/N] "
    read -r confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        step "Removing Vivado installation..."
        rm -rf "$VAM_HOME"
        success "Vivado uninstalled."

        if docker image inspect "$VAM_IMAGE" &>/dev/null; then
            step "Removing Docker image..."
            docker rmi "$VAM_IMAGE" &>/dev/null || true
            success "Docker image removed."
        fi
    else
        info "Cancelled."
    fi
}

usage() {
    cat << 'EOF'
vivado_at_mac (vam) v1.0.0 — Run Vivado on macOS

Usage: vam <command> [options]

Commands:
  install <bin>     Install Vivado from .bin installer
  build [dir]       Build bitstream (default: current directory)
  program [bit]     Program FPGA board
  gui [dir]         Open Vivado GUI in browser (noVNC)
  status            Show installation & container status
  clean [dir]       Remove build/ artifacts
  uninstall         Remove Vivado installation (~40GB)

Options:
  --board, -b       FPGA board name (for program)
  --help, -h        Show this help

Examples:
  vam install ~/Downloads/FPGAs_xxx_Lin64.bin
  vam build
  vam build ./examples/blinky/
  vam program --board basys3
  vam program build/top.bit -b arty
  vam gui

Project config (fpga.yml):
  project: my_project
  part: xc7a35ticsg324-1L
  top: top_module
  sources:
    - src/*.v
  constraints:
    - constraints/board.xdc
  board: basys3
EOF
}

#=== Main Dispatch ===#
main() {
    case "${1:-}" in
        install)   shift; cmd_install "$@" ;;
        build)     shift; cmd_build "$@" ;;
        program)   shift; cmd_program "$@" ;;
        gui)       shift; cmd_gui "$@" ;;
        status)    cmd_status ;;
        clean)     shift; cmd_clean "$@" ;;
        uninstall) cmd_uninstall ;;
        --help|-h) usage ;;
        "")        usage ;;
        *)         error "Unknown command: $1"; echo ""; usage; exit 1 ;;
    esac
}

main "$@"
